[
    // Ctrl+k → from terminal back to editor
    {
        "key": "ctrl+k",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "terminalFocus"
    },
    // Ctrl+l → from explorer back to editor
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "explorerViewletVisible && explorerViewletFocus"
    }
]