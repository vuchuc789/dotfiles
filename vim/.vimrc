" ---------- BASIC SETTINGS ----------
set nocompatible
syntax on
filetype plugin indent on

" ---------- UI ----------
set number
set ruler
set showcmd
set cursorline
set wildmenu
set lazyredraw
set ttyfast

" ---------- INDENTATION ----------
set tabstop=4
set shiftwidth=4
set expandtab
set smartindent
set autoindent

" ---------- SEARCH ----------
set ignorecase
set smartcase
set incsearch
set hlsearch

" ---------- EDITING ----------
set backspace=indent,eol,start
set clipboard=unnamedplus
set hidden
set nowrap

" ---------- SPLITS ----------
set splitbelow
set splitright

" ---------- KEY MAPS ----------
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

inoremap jk <Esc>
inoremap kj <Esc>
